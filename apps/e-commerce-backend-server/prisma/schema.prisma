datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  createdAt     DateTime @default(now())
  description   String?
  id            String   @id @default(cuid())
  name          String?
  orders        Order[]
  price         Float?
  sku           String?
  stockQuantity Int?
  updatedAt     DateTime @updatedAt
}

model Order {
  createdAt   DateTime         @default(now())
  id          String           @id @default(cuid())
  orderDate   DateTime?
  orderNumber String?
  product     Product?         @relation(fields: [productId], references: [id])
  productId   String?
  status      EnumOrderStatus?
  totalAmount Float?
  updatedAt   DateTime         @updatedAt
}

model User {
  createdAt DateTime @default(now())
  email     String?  @unique
  firstName String?
  id        String   @id @default(cuid())
  lastName  String?
  password  String
  roles     Json
  updatedAt DateTime @updatedAt
  username  String   @unique
}

model Cart {
  createdAt DateTime @default(now())
  id        String   @id @default(cuid())
  updatedAt DateTime @updatedAt
}

model Payment {
  createdAt DateTime @default(now())
  id        String   @id @default(cuid())
  updatedAt DateTime @updatedAt
}

model Shipping {
  createdAt DateTime @default(now())
  id        String   @id @default(cuid())
  updatedAt DateTime @updatedAt
}

enum EnumOrderStatus {
  Option1
}
